generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum GameStatus {
  WAITING
  IN_PROGRESS
  FINISHED
  ABANDONED
}

model Session {
  token           String      @id
  userId          Int         @unique
  user            User        @relation(fields: [userId], references: [id])
  expiresAt       DateTime
  createdAt       DateTime    @default(now())
}

model APIKey {
  token           String      @id
  scope           String      ///indicates whether key has user or admin access
  userId          Int         @unique
  user            User        @relation(fields: [userId], references: [id])
  expiresAt       DateTime
  createdAt       DateTime    @default(now())
}

model User {
  id             Int           @id @default(autoincrement())
  email          String        @unique
  name           String
  hashedPassword String
  createdAt      DateTime      @default(now())
  session        Session?
  apiKey         APIKey?
  gameResults    GameResult[]
  gameSessions   GameSession[]
}

model GameSession {
  id         Int          @id @default(autoincrement())
  status     GameStatus   @default(WAITING)
  roomkey    String       @unique
  charCount  Int
  wordCount  Int
  textPrompt String
  createdAt  DateTime     @default(now())
  startedAt  DateTime?
  finishedAt DateTime?
  results    GameResult[]
  players    User[]
}

model GameResult {
  id        Int         @id @default(autoincrement())
  score     Int
  wpm       Int
  cpm       Int
  accuracy  Float
  timeMs    Int
  placement Int
  finished  Boolean
  sessionId Int
  session   GameSession @relation(fields: [sessionId], references: [id])
  userId    Int?
  user      User?       @relation(fields: [userId], references: [id])
  guestName String?
}