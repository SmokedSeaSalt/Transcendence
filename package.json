{
  "name": "transcendence",
  "private": true,
  "workspaces": [
    "client",
    "server"
  ],
  "scripts": {
    "up": "docker-compose up",
    "prod": "docker-compose --env-file .env up --build",
    "dev": "docker compose -f docker-compose.yml -f docker-compose.dev.yml --env-file .env.dev up --build",
    "down": "docker-compose down",
    "lint": "biome check .",
    "format": "biome format --write .",
    "prisma:generate": "npm --workspace server run prisma:generate",
    "prisma:migrate": "npm --workspace server run prisma:migrate",
    "prisma:studio": "npm --workspace server run prisma:studio"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "concurrently": "^9.1.0"
  }
}