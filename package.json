{
	"name": "transcendence",
	"private": true,
	"workspaces": ["client", "server"],
	"scripts": {
		"up": "docker-compose up",
		"prod": "docker-compose up --build",
		"dev": "docker-compose -f docker-compose.yml -f docker-compose.dev.yml --env-file .env.dev up --build",
		"down": "docker-compose down",
		"reset_db": "docker-compose down -v",
		"lint": "biome check .",
		"format": "biome format --write .",
		"test": "echo 'No tests yet' && exit 0",
		"prisma:generate": "npm --workspace server run prisma:generate",
		"prisma:migrate": "docker exec -it server npx prisma migrate dev --name",
		"prisma:studio": "npm --workspace server run prisma:studio",
		"prisma:reset": "docker exec -it server npx prisma migrate reset --force"
	},
	"devDependencies": {
		"@biomejs/biome": "^1.9.4",
		"concurrently": "^9.1.0"
	}
}
