{
	"name": "server",
	"private": true,
	"type": "module",
	"scripts": {
		"dev": "tsx watch src/index.ts",
		"build": "tsc -p tsconfig.json",
		"start": "node dist/index.js",
		"test": "vitest run --config ./tests/vitest.config.ts",
		"test:watch": "vitest --config ./tests/vitest.config.ts",
		"prisma:generate": "prisma generate",
		"prisma:migrate:dev": "prisma migrate dev",
		"prisma:migrate:deploy": "prisma migrate deploy",
		"prisma:studio": "dotenv -e ../.env.dev -- bash -c 'DATABASE_URL=postgresql://$POSTGRES_USER:$POSTGRES_PASSWORD@localhost:5432/$POSTGRES_DB prisma studio'"
	},
	"dependencies": {
		"@prisma/client": "^6.19.3",
		"bcrypt": "^6.0.0",
		"cors": "^2.8.5",
		"dotenv": "^16.4.7",
		"express": "^4.21.2",
		"express-validator": "^7.3.2",
		"pg": "^8.13.1",
		"socket.io": "^4.8.3"
	},
	"devDependencies": {
		"@types/bcrypt": "^6.0.0",
		"@types/cors": "^2.8.17",
		"@types/express": "^5.0.0",
		"@types/node": "^24.13.2",
		"@types/supertest": "^7.2.0",
		"dotenv-cli": "^11.0.0",
		"prisma": "^6.19.3",
		"socket.io-client": "^4.8.3",
		"supertest": "^7.2.2",
		"tsx": "^4.19.2",
		"typescript": "^5.7.3",
		"vitest": "^4.1.9"
	}
}
